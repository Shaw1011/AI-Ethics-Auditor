# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# ── Required in production ────────────────────────────────────────────────────
SECRET_KEY=replace-with-a-random-64-char-hex-string
JWT_SECRET_KEY=replace-with-another-random-64-char-hex-string

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default, development only)
DATABASE_URL=sqlite:///data/app.db
# PostgreSQL (production)
# DATABASE_URL=postgresql://user:password@localhost:5432/ai_ethics_auditor

# ── Flask ─────────────────────────────────────────────────────────────────────
FLASK_ENV=development
FLASK_HOST=127.0.0.1
FLASK_PORT=5000

# ── Token lifetimes (seconds) ─────────────────────────────────────────────────
JWT_ACCESS_EXPIRES=3600
JWT_REFRESH_EXPIRES=604800

# ── Uploads ───────────────────────────────────────────────────────────────────
UPLOAD_DIR=data/models
MAX_UPLOAD_BYTES=52428800   # 50 MB

# ── CORS (comma-separated origins) ───────────────────────────────────────────
CORS_ORIGINS=http://localhost:5000

# ── Rate limiting ─────────────────────────────────────────────────────────────
# Use Redis in production: redis://localhost:6379/0
REDIS_URL=memory://
